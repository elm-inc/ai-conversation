# ai-conversation voice agent — 環境変数 (.env にコピーして埋める)

# Daily (Transport) — ローカル開発用。Pipecat Cloud では不要 (ルームは自動発行)
DAILY_API_KEY=
DAILY_ROOM_URL=

# Deepgram (STT)
DEEPGRAM_API_KEY=
STT_LANGUAGE=ja
STT_MODEL=nova-2

# Anthropic Claude (LLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ElevenLabs (TTS) — 声優の voice_id
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TTS_MODEL=eleven_flash_v2_5
